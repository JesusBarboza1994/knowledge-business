{
  "name": "template-mms",
  "version": "0.0.1",
  "description": "MMS Service Template",
  "author": "MenteMente",
  "private": true,
  "engines": {
    "node": ">=v20.18.0",
    "pnpm": ">=9.13.0"
  },
  "scripts": {
    "build": "nest build",
    "dev": "dotenv -e .env.dev -- nest start --watch",
    "start": "nest start",
    "start:debug": "dotenv -e .env.dev -- nest start --debug --watch",
    "start:prod": "node dist/main",
"format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs}/**/*.ts\" --fix",
    "test": "pnpm run test:unit",
    "test:ui": "pnpm run test:unit --ui",
    "test:ci": "dotenv -e .env.test -- vitest run --project unit",
    "test:cov": "dotenv -e .env.test -- vitest run --project unit --coverage",
    "test:unit": "dotenv -e .env.test -- vitest --project unit",
    "clean": "rimraf node_modules/ dist/ coverage/ pnpm-lock.yaml",
    "prepare": "husky"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nestjs/axios": "4.0.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "11.0.11",
    "@nestjs/config": "4.0.1",
    "@nestjs/core": "11.0.11",
    "@nestjs/mapped-types": "2.1.0",
    "@nestjs/mongoose": "11.0.1",
    "@nestjs/platform-express": "11.0.11",
    "@nestjs/swagger": "11.0.6",
    "axios": "1.8.3",
    "bullmq": "^5.66.5",
    "dayjs": "1.11.13",
    "express": "^4.21.2",
    "ioredis": "^5.9.2",
    "mongoose": "8.12.1",
    "mssql": "^12.5.5",
    "nestjs-pino": "4.3.1",
    "nestjs-zod": "4.3.1",
    "pino-pretty": "13.0.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.0",
    "@eslint/js": "9.22.0",
    "@nestjs/cli": "11.0.5",
    "@nestjs/schematics": "11.0.2",
    "@nestjs/testing": "11.0.11",
    "@types/express": "5.0.0",
    "@types/node": "22.13.10",
    "@typescript-eslint/eslint-plugin": "8.26.1",
    "@typescript-eslint/parser": "8.26.1",
    "@vitest/coverage-v8": "3.0.8",
    "@vitest/ui": "3.0.8",
    "dotenv-cli": "8.0.0",
    "eslint": "9.22.0",
    "eslint-config-prettier": "10.1.1",
    "eslint-plugin-prettier": "5.2.3",
    "globals": "16.0.0",
    "husky": "9.1.7",
    "prettier": "3.5.3",
    "rimraf": "6.0.1",
    "tsx": "^4.22.4",
    "typescript": "5.4.5",
    "unplugin-swc": "1.5.1",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "3.0.8"
  }
}
